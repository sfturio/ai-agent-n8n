N8N_WEBHOOK_URL="your url"
PORT=3000

SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_TABLE="agent_messages"

# n8n retry policy (429)
N8N_RETRY_MAX=2
N8N_RETRY_BASE_DELAY_MS=800
N8N_REQUEST_TIMEOUT_MS=45000
N8N_COLD_START_RETRY_DELAY_MS=3500
N8N_WARMUP_ON_BOOT=true
N8N_WARMUP_URL=""
N8N_WARMUP_TIMEOUT_MS=8000
N8N_WARMUP_METHOD=GET
N8N_READY_TTL_MS=120000
N8N_WARMUP_MAX_WAIT_MS=30000
N8N_WARMUP_POLL_INTERVAL_MS=3000

# API rate limit (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_BLOCK_MS=30000

# Metrics query
METRICS_SAMPLE_LIMIT=500
